PORT=5000
DATABASE_URL=mongodb://localhost:27017/urlshortener

# Session signing secret — generate with: openssl rand -hex 32
SECRET=replace_with_a_long_random_secret

# Public URL of this Express API
BASE_URL=http://localhost:5000

# React dashboard origin
FRONTEND_URL=http://localhost:5173

# Public short link domain and path
SHORT_LINK_BASE_URL=http://localhost:5000
SHORT_LINK_PATH=/go

# Holding page domain and path
HOLDING_PAGE_BASE_URL=http://localhost:5173
HOLDING_PAGE_PATH=/r

# CORS: dashboard origins allowed to send session cookies
ALLOWED_DASHBOARD_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# CORS: holding page origins for /api/resolve
ALLOWED_HOLDING_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

SHORTENER_API_URL=http://localhost:5000
