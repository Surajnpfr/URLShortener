PORT=5000
# MongoDB connection (either variable is accepted)
DATABASE_URL=mongodb://localhost:27017/urlshortener
# MONGODB_URI=mongodb+srv://user:pass@cluster.example.net/urlshortener

# Auth0 Regular Web Application (express-openid-connect session auth — not JWT audience)
ISSUER_BASE_URL=https://nerdy.jp.auth0.com
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret

# Session signing secret — generate with: openssl rand -hex 32
SECRET=replace_with_a_long_random_secret

# Public URL of this Express API (OAuth callback only — NOT used for logout redirect)
# Auth0 Allowed Callback URLs: BASE_URL/callback
# Local:  http://localhost:5000/callback
# Prod:   https://app.drovashop.com/callback
BASE_URL=http://localhost:5000

# React dashboard — Auth0 logout returnTo (Allowed Logout URLs in Auth0 dashboard)
# Must be https://drovashop.com in production — never https://app.drovashop.com
# Local:  http://localhost:5173
# Prod:   https://drovashop.com
FRONTEND_URL=http://localhost:5173

# Public short link domain and path
SHORT_LINK_BASE_URL=https://drovashop.com
SHORT_LINK_PATH=/go

# Holding page domain and path
HOLDING_PAGE_BASE_URL=https://hamroniti.com
HOLDING_PAGE_PATH=/r

# CORS: dashboard origins allowed to send session cookies
ALLOWED_DASHBOARD_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://drovashop.com,https://www.drovashop.com

# CORS: holding page origins for /api/resolve
ALLOWED_HOLDING_ORIGINS=https://hamroniti.com,https://www.hamroniti.com

# API host the holding page calls (usually same as BASE_URL in production)
SHORTENER_API_URL=https://app.drovashop.com

# --- Production overrides (on server / Hostinger) ---
# BASE_URL=https://app.drovashop.com          # API + OAuth callback only
# FRONTEND_URL=https://drovashop.com          # Auth0 logout returnTo
# VITE_API_URL=https://app.drovashop.com      # frontend/.env.production — API calls only
#
# Auth0 Application (nerdy.jp.auth0.com) settings:
#   Allowed Callback URLs:  https://app.drovashop.com/callback, http://localhost:5000/callback
#   Allowed Logout URLs:    https://drovashop.com, https://www.drovashop.com, http://localhost:5173
#   Allowed Web Origins:    https://drovashop.com, https://www.drovashop.com, http://localhost:5173
