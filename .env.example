PORT=5000
DATABASE_URL=mongodb://localhost:27017/urlshortener

# Backend API host (e.g. https://api.yourdomain.com)
BASE_URL=http://localhost:5000

# Public short link domain and path (e.g. https://links.yourdomain.com/go/:code)
SHORT_LINK_BASE_URL=http://localhost:5000
SHORT_LINK_PATH=/go

# Holding page domain and path (e.g. https://yourdomain.com/r/:code)
HOLDING_PAGE_BASE_URL=http://localhost:5173
HOLDING_PAGE_PATH=/r

# CORS: origins allowed to call dashboard API (e.g. https://app.yourdomain.com)
ALLOWED_DASHBOARD_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# CORS: origins allowed to call /api/resolve (holding page host)
ALLOWED_HOLDING_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# API host the holding page uses to resolve short codes (usually same as BASE_URL)
SHORTENER_API_URL=http://localhost:5000

# Frontend build-time variable (set in frontend/Dockerfile or .env.local):
# VITE_API_URL=http://localhost:5000
